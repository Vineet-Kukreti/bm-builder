# BM Builder - environment variable template
# ---------------------------------------------------------------------------
# Copy this file to ".env" and add your key(s):
#
#   Windows (PowerShell):  Copy-Item .env.example .env
#   macOS / Linux:         cp .env.example .env
#
# Then paste your Anthropic API key below and restart the app.
# Get a key at: https://console.anthropic.com/settings/keys
#
# ".env" is git-ignored so your real keys are never committed.
# You can also manage keys from the in-app Settings page.

ANTHROPIC_API_KEY=

# Optional: only needed if you route agents through OpenAI or an
# OpenAI-compatible endpoint (Groq, OpenRouter, ...).
# OPENAI_API_KEY=
